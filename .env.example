# ═══════════════════════════════════════════════════════════════════════════════
# FaceGuard — Конфігурація середовища
#
# Docker-запуск:  cp .env.example .env   (або просто:  make setup)
# Локально:       cp .env.example .env  і змінити DB_HOST=localhost, Redis на localhost
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Django ─────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-this-in-production-min-50-chars
DEBUG=False
# При Docker: web,localhost,127.0.0.1   При локально: localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── База даних ─────────────────────────────────────────────────────────────
DB_NAME=faceguard
DB_USER=faceguard
DB_PASSWORD=faceguard_secret
# Docker: DB_HOST=postgres   Локально: DB_HOST=localhost
DB_HOST=postgres
DB_PORT=5432

# ─── Redis ──────────────────────────────────────────────────────────────────
# ВАЖЛИВО: При Docker ці значення ПЕРЕВИЗНАЧАЮТЬСЯ docker-compose.yml
# (redis://redis:6379/...).  Тут залишаємо localhost для локального запуску.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── ML Налаштування ────────────────────────────────────────────────────────
# Детектор: "hog" (швидко, CPU) або "cnn" (точніше, потребує GPU/RAM)
FACE_DETECTOR_MODEL=hog
FACE_TOLERANCE=0.55
MIN_CONFIDENCE=45.0
LIVENESS_ENABLED=True
LIVENESS_THRESHOLD=0.20
LIVENESS_WARMUP_SECONDS=4.0
LIVENESS_COOLDOWN_SECONDS=5.0
LIVENESS_REQUIRED_BLINKS=1
LIVENESS_MIN_CLOSED_FRAMES=1
LIVENESS_MAX_CLOSED_FRAMES=8
LIVENESS_MIN_OPEN_FRAMES_BEFORE_BLINK=2
LIVENESS_MIN_VALID_EAR_FRAMES_FOR_BASELINE=8
LIVENESS_EAR_RELATIVE_DROP_RATIO=0.78
LIVENESS_EAR_RECOVERY_RATIO=0.88
LIVENESS_EAR_SMOOTHING_ALPHA=0.40
LIVENESS_MAX_MISSING_FRAMES=6
TEXTURE_MIN_FACE_SIZE_PX=48
TEXTURE_MIN_QUALITY_SCORE=0.08
LIVENESS_DEBUG_OVERLAY=False

# ─── Безпека (GDPR — шифрування біометрії) ──────────────────────────────────
# Fernet — симетричне шифрування з автентифікацією (AES-128-CBC + HMAC-SHA256).
# Генерувати:
#   python manage.py generate_fernet_key
#   або: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# make setup генерує автоматично
# УВАГА: не втрачайте ключ — без нього неможливо дешифрувати біометричні дані!
BIOMETRIC_ENCRYPTION_KEY=your-32-byte-base64-encoded-key-here

# ─── Медіа файли ────────────────────────────────────────────────────────────
MEDIA_ROOT=./media

# ─── CORS (для React dev-сервера — лише при локальному розробленні) ─────────
# При Docker цей рядок не потрібен (nginx сам маршрутизує)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
